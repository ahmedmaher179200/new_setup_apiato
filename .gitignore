# =========================
# Laravel / Apiato
# =========================
/vendor/
/node_modules/
/public/storage
/storage/*.key
/storage/logs/*
/storage/framework/cache/*
/storage/framework/sessions/*
/storage/framework/views/*
/bootstrap/cache/*

# Keep important empty folders
!/storage/logs/.gitignore
!/storage/framework/cache/.gitignore
!/storage/framework/sessions/.gitignore
!/storage/framework/views/.gitignore
!/bootstrap/cache/.gitignore

# =========================
# Environment
# =========================
.env
.env.*
!.env.example

# =========================
# Composer
# =========================
composer.lock

# =========================
# NPM / Yarn
# =========================
package-lock.json
yarn.lock
pnpm-lock.yaml

# =========================
# Build files
# =========================
/public/build
/public/hot
/public/mix-manifest.json

# =========================
# IDE / Editor
# =========================
/.idea
/.vscode
*.swp
*.swo

# =========================
# OS Files
# =========================
.DS_Store
Thumbs.db

# =========================
# Testing
# =========================
/phpunit.result.cache

# =========================
# Logs
# =========================
*.log

# =========================
# Apiato specific (optional)
# =========================
/app/Ship/Logs/*